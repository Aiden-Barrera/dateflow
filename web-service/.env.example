# Supabase — get these from your project dashboard at https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — used by VenueCache to cache Google Places results
# Get these from your Upstash console at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash — used to verify and trigger the internal venue-generation job
# Get these from your Upstash QStash dashboard
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Google Places API — used by PlacesAPIClient to fetch nearby venue candidates
# Get this from Google Cloud Console → APIs & Services → Credentials
# Enable "Places API (New)" on the project before using
GOOGLE_PLACES_API_KEY=

# Google Maps Embed API — optional, used to show the matched venue on the result page
# Use a browser-safe key with HTTP referrer restrictions
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=

# AI curation — optional; when disabled or unset, DS-03 falls back to deterministic ranking
AI_CURATION_ENABLED=false
AI_CURATION_PROVIDER=gemini
AI_CURATION_PROMPT_VERSION=v1
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Live event APIs (DS-07B)
# Ticketmaster Discovery API — register at developer.ticketmaster.com (5,000 calls/day free)
TICKETMASTER_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_ROLE_COOKIE_SECRET=
