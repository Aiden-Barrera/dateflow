# Supabase — get these from your project dashboard at https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — used by VenueCache to cache Google Places results
# Get these from your Upstash console at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash — used to verify and trigger the internal venue-generation job
# Get these from your Upstash QStash dashboard
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Google Places API — used by PlacesAPIClient to fetch nearby venue candidates
# Get this from Google Cloud Console → APIs & Services → Credentials
# Enable "Places API (New)" on the project before using
GOOGLE_PLACES_API_KEY=

# Anthropic — optional for AI curation; when unset, DS-03 falls back to deterministic ranking
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_ROLE_COOKIE_SECRET=
